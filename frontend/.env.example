# ── Обязательные ─────────────────────────────────────────────────────────────
# Адрес бекенда (NestJS). В dev — localhost, в проде — https://ojakh.api.whysargis.ru.
# ВАЖНО: NEXT_PUBLIC_* вшиваются в клиентский бандл на этапе сборки
# (next build); в Docker передаются как build args (см. docker-compose.yml).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Публичный адрес самого сайта — для canonical/OG-метаданных и sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Социальный вход (пусто → кнопка провайдера не показывается) ─────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
NEXT_PUBLIC_YANDEX_CLIENT_ID=

# ── Мониторинг (пусто → отключён) ────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
# Только для загрузки source maps при сборке (не попадает в бандл).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Разработка ────────────────────────────────────────────────────────────────
# true → фронтенд работает на мок-данных из lib/mock-data.ts без бекенда.
NEXT_PUBLIC_USE_MOCK=
