{
  "name": "backend",
  "version": "0.1.0",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts",
    "lint": "eslint \"{src,prisma,scripts}/**/*.ts\"",
    "lint:fix": "eslint \"{src,prisma,scripts}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,prisma,scripts}/**/*.ts\"",
    "format:check": "prettier --check \"{src,prisma,scripts}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "@sentry/nestjs": "^10.58.0",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.0.0",
    "file-type": "^16.5.4",
    "google-auth-library": "^10.6.1",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.15",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.5",
    "jest": "^30.2.0",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0"
  },
  "ts-node": {
    "esm": false,
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
