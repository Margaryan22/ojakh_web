generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  password         String?
  name             String
  phone            String?
  googleId         String?        @unique
  appleId          String?        @unique
  yandexId         String?        @unique
  role             String         @default("user")
  createdAt        DateTime       @default(now())
  cart             Cart?
  orders           Order[]
  notifications    Notification[]
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  flavor      String?
  size        String?
  weightGrams Int?
  unit        String  @default("шт")
  price       Int
  imageUrl    String?
  description String?
  ingredients String?
  available   Boolean @default(true)
  maxPerDay   Int     @default(999)
  minQty      Float   @default(1)   // минимальное количество в заказе
  step        Float   @default(1)   // шаг изменения количества
  calories    Float   @default(0)   // ккал на 100 г
  protein     Float   @default(0)   // белки, г на 100 г
  fat         Float   @default(0)   // жиры, г на 100 г
  carbs       Float   @default(0)   // углеводы, г на 100 г
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Json     @default("[]")
  updatedAt DateTime @updatedAt
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id           Int       @id @default(autoincrement())
  orderNumber  String?   @unique
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  items        Json
  subtotal     Int
  deliveryCost Int       @default(0)
  total        Int
  status       String    @default("new")
  address      String?
  deliveryDate DateTime  @db.Date
  deliveryTime String?
  isPickup     Boolean   @default(false)
  paymentId    String?
  createdAt    DateTime  @default(now())
  paidAt       DateTime?
  readyAt      DateTime?

  @@index([userId])
  @@index([deliveryDate])
  @@index([status])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   Int
  status    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── DailyLimit ───────────────────────────────────────────────────────────────

model DailyLimit {
  deliveryDate DateTime @id @db.Date
  maxUnits     Int      @default(100)
  maxTorts     Int      @default(2)
}

