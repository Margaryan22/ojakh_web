generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  password            String?
  name                String
  phone               String?              @unique
  googleId            String?              @unique
  appleId             String?              @unique
  yandexId            String?              @unique
  role                String               @default("user")
  createdAt           DateTime             @default(now())
  cart                Cart?
  orders              Order[]
  notifications       Notification[]
  reviews             Review[]
  addresses           UserAddress[]
  feedback            Feedback[]
  favorites           Favorite[]
  pushSubscriptions   PushSubscription[]
  passwordResets      PasswordResetToken[]
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  flavor      String?
  size        String?
  weightGrams Int?
  unit        String  @default("шт")
  price       Int
  imageUrl    String?
  description String?
  ingredients String?
  available   Boolean @default(true)
  maxPerDay   Int     @default(999)
  minQty      Float   @default(1)   // минимальное количество в заказе
  step        Float   @default(1)   // шаг изменения количества
  calories    Float   @default(0)   // ккал на 100 г
  protein     Float   @default(0)   // белки, г на 100 г
  fat         Float   @default(0)   // жиры, г на 100 г
  carbs       Float   @default(0)   // углеводы, г на 100 г
  label       String?                // 'hit' | 'new' | 'sale' | 'recommended' | 'seasonal' | 'limited'
  reviews     Review[]
  favorites   Favorite[]
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  rating    Int
  text      String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, createdAt])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Json     @default("[]")
  updatedAt DateTime @updatedAt
}

// ─── Favorites ────────────────────────────────────────────────────────────────

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                       Int       @id @default(autoincrement())
  orderNumber              String?   @unique
  userId                   Int
  user                     User      @relation(fields: [userId], references: [id])
  items                    Json
  subtotal                 Int
  deliveryCost             Int       @default(0)
  discountKopecks          Int       @default(0)
  promoCode                String?
  total                    Int
  status                   String    @default("new")
  address                  String?
  addressApartment         String?
  addressEntrance          String?
  addressFloor             String?
  addressIntercom          String?
  deliveryNotes            String?   @db.VarChar(500)
  addressLat               Float?
  addressLon               Float?
  recipientName            String?
  contactPhone             String?
  deliveryDate             DateTime  @db.Date
  deliveryTime             String?
  isPickup                 Boolean   @default(false)
  paymentId                String?
  createdAt                DateTime  @default(now())
  paidAt                   DateTime?
  readyAt                  DateTime?

  dispatchedAt             DateTime?
  deliveryRecalcKopecks    Int?
  deliverySurchargeKopecks Int?
  recalcId                 String?
  recalcExpiresAt          DateTime?
  doplataPaymentId         String?   @unique
  doplataPaidAt            DateTime?

  yandexClaimId            String?   @unique
  yandexClaimStatus        String?

  paymentExpiresAt         DateTime?

  messages                 OrderMessage[]
  payments                 Payment[]

  @@index([userId])
  @@index([deliveryDate])
  @@index([status])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String    @id @default(uuid())
  orderId           Int
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kind              String    // 'main' | 'doplata'
  provider          String    // 'yookassa' | 'manual'
  providerPaymentId String?   @unique // id платежа в ЮKassa
  status            String    @default("pending") // pending | succeeded | canceled
  amountKopecks     Int
  confirmationToken String?
  createdAt         DateTime  @default(now())
  paidAt            DateTime?
  canceledAt        DateTime?

  @@index([orderId, kind])
}

// ─── OrderMessages ────────────────────────────────────────────────────────────

model OrderMessage {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderRole  String   // "user" | "admin"
  senderId    Int      // userId автора
  text        String   @db.VarChar(2000)
  readByUser  Boolean  @default(false)
  readByAdmin Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([readByAdmin])
  @@index([readByUser])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   Int?     // null — для массовых объявлений (broadcast), не привязанных к заказу
  status    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── UserAddress ──────────────────────────────────────────────────────────────

model UserAddress {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?  // "Дом", "Работа" — необязательная метка
  address   String
  lat       Float?
  lon       Float?
  apartment String?
  entrance  String?
  floor     String?
  intercom  String?
  notes     String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Feedback ─────────────────────────────────────────────────────────────────

enum FeedbackKind {
  idea
  question
  complaint
  praise
}

model Feedback {
  id        Int          @id @default(autoincrement())
  userId    Int?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  kind      FeedbackKind
  text      String       @db.VarChar(2000)
  readAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([createdAt])
  @@index([readAt])
}

// ─── DailyLimit ───────────────────────────────────────────────────────────────

model DailyLimit {
  deliveryDate   DateTime @id @db.Date
  maxUnits       Int      @default(100)
  maxTorts       Int      @default(2)
  // Override per-slot capacity. Keys are slot labels из DELIVERY_TIME_SLOTS
  // (например "18:00-19:00"); отсутствующие ключи → DEFAULT_SLOT_CAPACITY.
  slotCapacities Json?
  isBlackedOut   Boolean  @default(false)
  blackoutReason String?
}

// ─── StoreSettings ──────────────────────────────────────────────────────────
// Глобальные настройки магазина, редактируемые из админки. Единственная строка
// (id = 1). Значения по умолчанию совпадают с константами в common/constants.ts:
// MIN_ORDER_KOPECKS и FREE_DELIVERY_THRESHOLD_KOPECKS — они же используются как
// fallback в коде, если строка ещё не создана.

model StoreSettings {
  id                           Int      @id @default(1)
  minOrderKopecks              Int      @default(100000)
  freeDeliveryThresholdKopecks Int      @default(400000)
  updatedAt                    DateTime @updatedAt
}

// ─── PromoCode ────────────────────────────────────────────────────────────────
// Промокоды, редактируемые из админки. code хранится в верхнем регистре,
// сравнение регистронезависимое. type: 'percent' (value 1..100) | 'fixed'
// (value в копейках). usedCount растёт атомарно при оформлении заказа.

model PromoCode {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  type            String    // 'percent' | 'fixed'
  value           Int       // percent: 1..100; fixed: копейки
  minOrderKopecks Int       @default(0)
  maxUses         Int?      // null = безлимит
  usedCount       Int       @default(0)
  perUserOnce     Boolean   @default(false)
  startsAt        DateTime?
  expiresAt       DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

// ─── PasswordResetToken ───────────────────────────────────────────────────────
// Одноразовая ссылка сброса пароля. Письма не отправляются: ссылку выдаёт
// администратор из админки и передаёт клиенту любым каналом (WhatsApp,
// Telegram, SMS). Хранится только sha256-хэш токена; сам токен виден один раз.

model PasswordResetToken {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdById Int? // id администратора, выдавшего ссылку
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ─── PushSubscription ─────────────────────────────────────────────────────────
// Web-push подписка браузера (один пользователь → несколько устройств).
// При ответе 404/410 от push-сервиса подписка удаляется как протухшая.

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

