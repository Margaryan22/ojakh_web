generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  password            String?
  name                String
  phone               String?              @unique
  googleId            String?              @unique
  appleId             String?              @unique
  yandexId            String?              @unique
  role                String               @default("user")
  createdAt           DateTime             @default(now())
  cart                Cart?
  orders              Order[]
  notifications       Notification[]
  reviews             Review[]
  addresses           UserAddress[]
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  flavor      String?
  size        String?
  weightGrams Int?
  unit        String  @default("шт")
  price       Int
  imageUrl    String?
  description String?
  ingredients String?
  available   Boolean @default(true)
  maxPerDay   Int     @default(999)
  minQty      Float   @default(1)   // минимальное количество в заказе
  step        Float   @default(1)   // шаг изменения количества
  calories    Float   @default(0)   // ккал на 100 г
  protein     Float   @default(0)   // белки, г на 100 г
  fat         Float   @default(0)   // жиры, г на 100 г
  carbs       Float   @default(0)   // углеводы, г на 100 г
  reviews     Review[]
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  rating    Int
  text      String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, createdAt])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Json     @default("[]")
  updatedAt DateTime @updatedAt
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id                       Int       @id @default(autoincrement())
  orderNumber              String?   @unique
  userId                   Int
  user                     User      @relation(fields: [userId], references: [id])
  items                    Json
  subtotal                 Int
  deliveryCost             Int       @default(0)
  total                    Int
  status                   String    @default("new")
  address                  String?
  addressApartment         String?
  addressEntrance          String?
  addressFloor             String?
  addressIntercom          String?
  deliveryNotes            String?   @db.VarChar(500)
  addressLat               Float?
  addressLon               Float?
  recipientName            String?
  contactPhone             String?
  deliveryDate             DateTime  @db.Date
  deliveryTime             String?
  isPickup                 Boolean   @default(false)
  paymentId                String?
  createdAt                DateTime  @default(now())
  paidAt                   DateTime?
  readyAt                  DateTime?

  dispatchedAt             DateTime?
  deliveryRecalcKopecks    Int?
  deliverySurchargeKopecks Int?
  recalcId                 String?
  recalcExpiresAt          DateTime?
  doplataPaymentId         String?   @unique
  doplataPaidAt            DateTime?

  messages                 OrderMessage[]

  @@index([userId])
  @@index([deliveryDate])
  @@index([status])
}

// ─── OrderMessages ────────────────────────────────────────────────────────────

model OrderMessage {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderRole  String   // "user" | "admin"
  senderId    Int      // userId автора
  text        String   @db.VarChar(2000)
  readByUser  Boolean  @default(false)
  readByAdmin Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([readByAdmin])
  @@index([readByUser])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   Int
  status    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── UserAddress ──────────────────────────────────────────────────────────────

model UserAddress {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?  // "Дом", "Работа" — необязательная метка
  address   String
  lat       Float?
  lon       Float?
  apartment String?
  entrance  String?
  floor     String?
  intercom  String?
  notes     String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── DailyLimit ───────────────────────────────────────────────────────────────

model DailyLimit {
  deliveryDate   DateTime @id @db.Date
  maxUnits       Int      @default(100)
  maxTorts       Int      @default(2)
  // Override per-slot capacity. Keys are slot labels из DELIVERY_TIME_SLOTS
  // (например "18:00-19:00"); отсутствующие ключи → DEFAULT_SLOT_CAPACITY.
  slotCapacities Json?
  isBlackedOut   Boolean  @default(false)
  blackoutReason String?
}

