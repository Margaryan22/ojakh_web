DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
NODE_ENV=development
PORT=3001
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
FRONTEND_URL=http://localhost:3000
UPLOADS_DIR=./uploads
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
DADATA_API_KEY=
DADATA_SECRET_KEY=
TWOGIS_API_KEY=
ABSTRACT_API_KEY=
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
YANDEX_CLIENT_ID=
RECALC_TTL_SECONDS=300
VERIFICATION_PEPPER=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ЮKassa (https://yookassa.ru/my). Пусто → ручной режим (реквизиты).
# Вебхук в кабинете: https://ojakh.api.whysargis.ru/payments/yookassa/webhook
# события payment.succeeded и payment.canceled.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_API_BASE=https://api.yookassa.ru/v3
# Чеки 54-ФЗ («ЮKassa Чеки» в кабинете). YOOKASSA_SEND_RECEIPT=0 — не слать чек.
# YOOKASSA_VAT_CODE: 1 = без НДС (УСН), 2 = 0%, 3 = 10%, 4 = 20%.
# YOOKASSA_TAX_SYSTEM_CODE — только если в кабинете несколько СНО (1..6).
YOOKASSA_SEND_RECEIPT=1
YOOKASSA_VAT_CODE=1
YOOKASSA_TAX_SYSTEM_CODE=

# Яндекс Доставка (Claims API, OAuth-токен из кабинета).
# Пусто → локальный расчёт, курьер вызывается вручную.
# Тестовая среда: YANDEX_DELIVERY_API_BASE=https://b2b.taxi.tst.yandex.net
YANDEX_DELIVERY_TOKEN=
YANDEX_DELIVERY_API_BASE=https://b2b.taxi.yandex.net
YANDEX_DELIVERY_CONTACT_PHONE=

# Sentry (мониторинг ошибок). Пусто → отключён (ничего не отправляется).
# DSN берётся из проекта Sentry (Settings → Client Keys).
SENTRY_DSN=
# Доля трасс для перформанс-мониторинга (0..1). 0 — только ошибки.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Web-push (уведомления о статусе заказа). Пусто → отключён.
# Сгенерировать пару ключей: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ojakh.ru

# Email-уведомления о статусе заказа через UniSender.
# Пусто → отключены (silent no-op).
# API ключ: личный кабинет UniSender → Настройки → Интеграции → API.
# MAIL_FROM_EMAIL — верифицированный email отправителя в аккаунте UniSender.
UNISENDER_API_KEY=
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Ojakh
